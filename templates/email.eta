<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<title>Bio Daily — <%= it.dateKST %></title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; max-width: 720px; margin: 0 auto; padding: 24px; color: #1a1a1a; }
  h1 { font-size: 22px; margin-bottom: 4px; }
  h2 { font-size: 16px; margin-top: 28px; border-bottom: 2px solid #eee; padding-bottom: 6px; }
  .summary { background: #f7f7f8; padding: 16px; border-left: 4px solid #2c5282; white-space: pre-wrap; line-height: 1.6; }
  .theme { margin: 16px 0; }
  .theme h3 { margin: 0 0 4px; font-size: 14px; color: #2c5282; }
  .article { padding: 12px 0; border-bottom: 1px solid #eee; }
  .article-title a { color: #1a1a1a; text-decoration: none; font-weight: 600; }
  .article-meta { color: #666; font-size: 12px; margin: 4px 0; }
  .read-point { background: #fff8e1; padding: 8px 10px; border-radius: 4px; font-size: 13px; }
  .footer { margin-top: 32px; color: #999; font-size: 11px; }
</style>
</head>
<body>
  <h1>📧 Bio Daily — <%= it.dateKST %></h1>

  <h2>Executive Summary</h2>
  <div class="summary"><%= it.insights.executiveSummary %></div>

  <% if (it.insights.themes.length > 0) { %>
    <h2>Themes</h2>
    <% it.insights.themes.forEach(function(t) { %>
      <div class="theme">
        <h3><%= t.title %></h3>
        <div><%= t.summary %></div>
      </div>
    <% }) %>
  <% } %>

  <h2>Top <%= it.articles.length %> Articles</h2>
  <% it.articles.forEach(function(a, i) { %>
    <div class="article">
      <div class="article-title"><a href="<%= a.url %>"><%= a.title %></a></div>
      <div class="article-meta"><%= a.source %> · <%= a.publishedAt %></div>
      <% if (it.insights.perArticle[i]) { %>
        <div class="read-point">💡 <%= it.insights.perArticle[i].readPoint %></div>
      <% } %>
    </div>
  <% }) %>

  <div class="footer">Auto-generated by bio-news at <%= new Date().toISOString() %></div>
</body>
</html>
