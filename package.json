{
  "name": "bio-news",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "news:daily": "node scripts/run-daily.mjs",
    "news:dry-run": "node scripts/run-daily.mjs --dry-run",
    "news:from-cache": "node scripts/run-daily.mjs --from-cache=insights",
    "test": "node --test tests/*.test.mjs",
    "test:integration": "INTEGRATION=1 node --test tests/*.test.mjs",
    "install:launchd": "node scripts/install-launchd.mjs",
    "uninstall:launchd": "node scripts/uninstall-launchd.mjs",
    "clean": "rm -rf output/20*"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "eta": "^3.4.0",
    "nodemailer": "^6.9.14",
    "openai": "^4.65.0",
    "zod": "^3.23.8"
  }
}
